# Get a free key at https://aistudio.google.com/apikey (no credit card required)
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model to use. flash is fast + free-tier friendly.
GEMINI_MODEL=gemini-flash-latest

# SQLite by default (zero cost, file-based). To use Postgres later, set e.g.:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/netagent
DATABASE_URL=sqlite+aiosqlite:///./netagent.db

# Where the Chroma vector store persists on disk
CHROMA_PERSIST_DIR=./chroma_store

# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000
